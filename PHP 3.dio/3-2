        <div class="rezultat-vrijednost">
            <?php
            if ($greska) {
                echo "<span class='greska'>" . htmlspecialchars($greska) . "</span>";
            } elseif ($rezultat !== null) {
                // Lijepo prikazati — bez nepotrebnih decimala
                $prikaz = (floor($rezultat) == $rezultat) ? (int)$rezultat : round($rezultat, 4);
                echo $broj1 . " " . htmlspecialchars($operacija) . " " . $broj2 . " = <strong>" . $prikaz . "</strong>";
            }
            ?>
        </div>

        <div class="btn-row">
            <button type="button" class="btn-op <?php echo ($operacija == '+') ? 'active' : ''; ?>"
                    onclick="postaviOp('+')">+</button>
            <button type="button" class="btn-op <?php echo ($operacija == '-') ? 'active' : ''; ?>"
                    onclick="postaviOp('-')">-</button>
            <button type="button" class="btn-op <?php echo ($operacija == '*') ? 'active' : ''; ?>"
                    onclick="postaviOp('*')">*</button>
            <button type="button" class="btn-op <?php echo ($operacija == '/') ? 'active' : ''; ?>"
                    onclick="postaviOp('/')">/</button>
