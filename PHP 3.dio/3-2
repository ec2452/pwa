<?php
$broj1     = null;
$broj2     = null;
$operacija = null;
$rezultat  = null;
$greska    = null;

if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $broj1     = $_POST["broj1"];
    $broj2     = $_POST["broj2"];
    $operacija = $_POST["operacija"];

    if ($broj1 !== "" && $broj2 !== "") {
        $broj1 = (float)$broj1;
        $broj2 = (float)$broj2;

        switch ($operacija) {
            case "+":
                $rezultat = $broj1 + $broj2;
                break;
            case "-":
                $rezultat = $broj1 - $broj2;
                break;
            case "*":
                $rezultat = $broj1 * $broj2;
                break;
            case "/":
                if ($broj2 == 0) {
                    $greska = "Dijeljenje s nulom nije dozvoljeno!";
                } else {
                    $rezultat = $broj1 / $broj2;
                }
                break;
            default:
                $greska = "Nepoznata operacija.";
        }
    } else {
        $greska = "Molimo unesite oba broja.";
    }
}
?>
