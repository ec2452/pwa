<?php
$ocjene        = [];
$prosjek       = null;
$konacnaOcjena = null;
$poruka        = null;
$greska        = null;

if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $k1 = $_POST["kolokvij1"];
    $k2 = $_POST["kolokvij2"];

    // Provjera jesu li uneseni
    if ($k1 === "" || $k2 === "") {
        $greska = "Molimo unesite obje ocjene.";
    } else {
        $k1 = (float)$k1;
        $k2 = (float)$k2;

        // Provjera raspona (1–5)
        if ($k1 < 1 || $k1 > 5 || $k2 < 1 || $k2 > 5) {
            $greska = "Ocjena mora biti između 1 i 5!";
        } else {
            // Polje ocjena
            $ocjene = array($k1, $k2);

            // Izračun prosjeka
            $prosjek = ($ocjene[0] + $ocjene[1]) / 2;

            // Ako je jedan kolokvij negativan (ocjena 1) — krajnja je negativna
            if ($ocjene[0] < 2 || $ocjene[1] < 2) {
                $konacnaOcjena = 1;
                $poruka        = "negativna";
            } else {
                $konacnaOcjena = round($prosjek);
                $poruka        = "pozitivna";
            }
        }
    }
}
