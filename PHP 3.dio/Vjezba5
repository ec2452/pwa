<?php
  $autor = "Ema Čurla";

  // Generiraj ili zadrži zamišljeni broj u GET parametru
  if (isset($_GET['pogodak'])) {
    // Forma je poslana — zadrži isti zamišljeni broj
    $zamisljenBroj = isset($_GET['zamisljen']) ? (int) $_GET['zamisljen'] : rand(1, 9);
    $uneseni       = (int) $_GET['pogodak'];
    $pogodio       = ($uneseni === $zamisljenBroj);
    $prikaziRezultat = true;
  } else {
    // Novi posjet — generiraj novi broj
    $zamisljenBroj   = rand(1, 9);
    $uneseni         = null;
    $prikaziRezultat = false;
  }
?>
